---
import { getAllPosts } from '@/utils/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();

  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<h1>{post.data.title}</h1>
<p>{post.data.pubDate.toDateString()}</p>
<article>
  {post.body}
</article>
