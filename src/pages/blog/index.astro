---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Optional: sort by date
posts.sort((a, b) => b.data.pubDate - a.data.pubDate);
---

<h1>Blog</h1>

<ul>
  {posts.map(post => (
    <li>
      <a href={`/blog/${post.slug}`}>{post.data.title}</a>
    </li>
  ))}
</ul>
